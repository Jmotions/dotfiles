{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-left": ["clock", "custom/pacman", "custom/notifications", "custom/spotify"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["group/expand", "bluetooth", "network", "battery", "pulseaudio","custom/power"],

    "custom/scrcpy_camera": {
        "format": "󰄟 {}",
        "exec": "/home/jahmad/.config/waybar/scripts/scrcpy_camera_module.sh",
        "return-type": "json",
        "interval": 1,
        "on-click": "/home/jahmad/.config/waybar/scripts/scrcpy_camera_module.sh 1",
        "on-click-middle": "/home/jahmad/.config/waybar/scripts/scrcpy_camera_module.sh 2",
        "on-click-right": "/home/jahmad/.config/waybar/scripts/scrcpy_camera_module.sh 3"

    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "",
            "default": "",
            "empty": ""
        },
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5]
        }
    },

  

    "clock": {
    "format": "{:%I:%M:%S %p} ",
    "interval": 1,
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
        "format": {
            "today": "<span color='#fAfBfC'><b>{}</b></span>"
        }
    },
    "actions": {
        "on-click": "shift_up",
        "on-click-right": "shift_down"
    },
    "on-click-middle": "kitty -e calcure"
},



    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "",
        "tooltip-format-disconnected": "Error",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) ",
        "tooltip-format-ethernet": "{ifname} 🖧",
        "on-click": "~/impalawifi.sh"
},

    "bluetooth": {
        "format-on": "󰂯",
        "format-off": "BT-off",
        "format-disabled": "󰂲",
        "format-connected-battery": "{device_battery_percentage}% 󰂯",
        "format-alt": "{device_alias} 󰂯",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
       "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
        "on-click": "vicinae vicinae://extensions/Gelei/bluetooth/scan",
        "on-click-middle": "vicinae vicinae://extensions/Gelei/bluetooth/devices"
},

    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% 󰂄",
        "format-plugged": "{capacity}% 󰂄 ",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "󰁻", "󰁼", "󰁾", "󰂀", "󰂂", "󰁹"
        ]
    },

"custom/spotify": {
    "exec": "/home/jahmad/.config/waybar/scripts/spotify.sh",
    "return-type": "plain-text",
    "interval": 0.5,
    "format": "{}",
    "tooltip": false,
    "on-click": "playerctl --player=deezer play-pause",
    "on-click-right": "playerctl --player=deezer next",
    "on-click-middle": "playerctl --player=deezer previous"
},
    
        "custom/pacman": {
        "format": "󰅢 {}",
        "interval": 30,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "kitty sh -c 'yay -Syu; echo Done - Press enter to exit; read'; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false
    },

    "custom/expand": {
        "format": "",
        "tooltip": false
    },
"custom/expand-left": {
        "format": "",
        "tooltip": false
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },

    "custom/power": {
    "tooltip": "Power menu",
    "format": "⏻",
    "on-click": "cpmenu -l ~/.config/cpmenu/layout -C ~/.config/cpmenu/style.css"
},

    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
            "tray",
            "cpu",
            "memory",
            "temperature",
            "custom/brightness",
            "custom/endpoint"
        ]
    },

    "custom/colorpicker": {
        "format": "{}",
        "return-type": "json",
        "interval": "once",
        "exec": "~/.config/waybar/scripts/colorpicker.sh -j",
        "on-click": "~/.config/waybar/scripts/colorpicker.sh",
        "signal": 1
    },

    "cpu": {
        "format": "󰻠",
        "tooltip": true,
        "on-click": "vicinae vicinae://extensions/leonkohli/process-manager/processes"
    
},

    "memory": {
        "format": ""
    },

    "temperature": {
        "critical-threshold": 80,
        "format": ""
    },

    "tray": {
        "icon-size": 14,
        "spacing": 10
    },
        "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 Muted",
        "format-icons": {
            "default": [
                "󰕿", // low
                "󰖀", // medium
                "󰕾"  // high
            ],
            "muted": "󰝟"
        },
        "on-click": "vicinae vicinae://extensions/rastsislaux/pulseaudio/pulseaudio",
        "on-click-middle": "pavucontrol",
        "tooltip": true
    },
    "custom/tray-wrapper": {
    "format": "{}",
    "tooltip": false,
    "exec": "true"
},

"custom/notifications": {
    "format": " {}",
    "interval": 2,
    "exec": "swaync-client -c | head -n 1",
    "on-click": "swaync-client -t",
    "signal": 9,
    "tooltip": false
},
"custom/fsel": {
    "format": "",
    "on-click": "~/fselwaybar.sh"
}
    
}
