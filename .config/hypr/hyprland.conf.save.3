# #######################################################################################
# AUTOGENERATED HYPRLAND CONFIG.
# PLEASE USE THE CONFIG PROVIDED IN THE GIT REPO /examples/hyprland.conf AND EDIT IT,
# OR EDIT THIS ONE ACCORDING TO THE WIKI INSTRUCTIONS.
# #######################################################################################

source = ~/.cache/wal/colors-hyprland.conf

################
### MONITORS ###
################
monitor = DP-3, 1920x1080@180, 0x0, 1
monitor = HDMI-A-1, 1920x1080@60, 0x-1080, 1
workspace = 1,monitor:DP-3
workspace = 2,monitor:HDMI-A-1

###################
### MY PROGRAMS ###
###################
$terminal = kitty
$fileManager = nautilus
$menu = kitty --title launcher -e bash -c "fsel --systemd-run -vv"
$clipboard = kitty --title launcher -e bash -i -c "fsel --cclip"
$browser = ~/Desktop/zen/zen
$wallset = kitty --class=wallset -e bash -i -c "~/wallpapermpv.sh"
$screenshot = bash -c 'mkdir -p /home/jahmad/Pictures/screenshots && ts=$(date +%Y-%m-%d_%H-%M-%S) && fp="/home/jahmad/Pictures/screenshots/screenshot-$ts.png" && grim -g "$(slurp)" "$fp" && swappy -f "$fp"'
$gemini = kitty -e bash -i -c "./home/jahmad/gemini/gemini.sh"
$taildrop = ~/bin/taildrop-rofi
$encfs_menu = kitty --title encfs-manager -e /home/jahmad/bin/encfs_tui.sh

#################
### AUTOSTART ###
#################
exec-once = hyprctl setcursor Bibata-Modern-Ice 24
exec-once = waybar & ./.config/wallset-engine/wallpaper_startup.sh
exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec-once = sunshine
exec-once = tailscale up
exec-once = cclipd -s 2 -t "image/png" -t "image/*" -t "text/plain;charset=utf-8" -t "text/*" -t "*" &
#exec-once = kitty --single-instance -o allow_remote_control=yes --listen-on unix:/tmp/mykitty.socket --start-as=hidden
exec-once = ~/cclipd.sh
############################
### ENVIRONMENT VARIABLES ###
#############################
env = HYPRCURSOR_THEME,Bibata-Modern-Ice
env = HYPRCURSOR_SIZE,24  
env = QT_QPA_PLATFORMTHEME,qt5ct
env = QT_STYLE_OVERRIDE,qt5ct
env = HYPR_ENABLE_HYPRCURSOR,1

###################
### LOOK AND FEEL ###
###################
general {
    gaps_in = 5
    gaps_out = 8
    border_size = 3
    resize_on_border = false
    allow_tearing = false
    col.active_border = $color3 $color2 $color10 45deg
    col.inactive_border = $background $color2 45deg
    layout = dwindle
}

decoration {
    rounding = 10
    rounding_power = 2
    active_opacity = 1.0
    inactive_opacity = 1.0

    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }

    blur {
        enabled = true
        size = 12
        passes = 3
        xray = false
        vibrancy = 0.1696
        new_optimizations = true
        ignore_opacity = true
    }
}

$iopacity = 0.94
$oopacity = 0.76
windowrulev2 = opacity $iopacity $oopacity, class:^(kitty)$
windowrulev2 = opacity 1.0 0.94, class:^(zen)$
windowrulev2 = opacity 0.5 override,title:^(Picture in picture)$
windowrulev2 = opacity 0.9 override,class:^(rofi)$
windowrulev2 = rounding 20,class:^(rofi)$

animations {
    enabled = yes, please :)
    bezier = easeOutQuint,0.23,1,0.32,1
    bezier = easeInOutCubic,0.65,0.05,0.36,1
    bezier = linear,0,0,1,1
    bezier = almostLinear,0.5,0.5,0.75,1.0
    bezier = quick,0.15,0,0.1,1
    animation = global, 1, 10, default
    animation = border, 1, 5.39, easeOutQuint
    animation = windows, 1, 4.79, easeOutQuint
    animation = windowsIn, 1, 4.1, easeOutQuint, popin 87%
    animation = windowsOut, 1, 1.49, linear, popin 87%
    animation = fadeIn, 1, 1.73, almostLinear
    animation = fadeOut, 1, 1.46, almostLinear
    animation = fade, 1, 3.03, quick
    animation = layers, 1, 3.81, easeOutQuint
    animation = layersIn, 1, 4, easeOutQuint, fade
    animation = layersOut, 1, 1.5, linear, fade
    animation = fadeLayersIn, 1, 1.79, almostLinear
    animation = fadeLayersOut, 1, 1.39, almostLinear
    animation = workspaces, 1, 1.94, almostLinear, fade
    animation = workspacesIn, 1, 1.21, almostLinear, fade
    animation = workspacesOut, 1, 1.94, almostLinear, fade
}

dwindle {
    pseudotile = true
    preserve_split = true
}

master {
    new_status = master
}

misc {
    force_default_wallpaper = -1
    disable_hyprland_logo = false
}

input {
    kb_layout = us
    follow_mouse = 1
    sensitivity = 0
    touchpad {
        natural_scroll = false
    }
}

device {
    name = epic-mouse-v1
    sensitivity = -0.5
}

$mainMod = SUPER

###################
### KEYBINDINGS ###
###################
bind = $mainMod, T, exec, $terminal
bind = $mainMod, Q, killactive,
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, F, fullscreen
bind = $mainMod, W, togglefloating,
bind = $mainMod, A, exec, $menu
bind = $mainMod SHIFT, A, exec, $clipboard
bind = $mainMod SHIFT, E, exec, $encfs_menu
bind = $mainMod, J, togglesplit,
bind = $mainMod, B, exec, $browser
bind = $mainMod SHIFT, W, exec, $wallset
bind = $mainMod SHIFT, Y, exec, killall -SIGUSR1 waybar
bind = $mainMod, Y, exec, waybar
bind = $mainMod, P, exec, $screenshot
bind = $mainMod SHIFT, T, exec, $taildrop
bind = $mainMod SHIFT, left, movewindow, l
bind = $mainMod SHIFT, right, movewindow, r
bind = $mainMod SHIFT, up, movewindow, t
bind = $mainMod SHIFT, down, movewindow, d
bind = $mainMod, L, focuswindow, title:^(Picture in picture)$
bind = CTRL, Space, global, menu.kando.Kando:example-menu

# Workspaces
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Scratchpad
bind = $mainMod, S, togglespecialworkspace, magic
bind = $mainMod SHIFT, S, movetoworkspace, special:magic

# Scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize mouse
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Multimedia keys
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-

bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

##############################
### WINDOWS AND WORKSPACES ###
##############################
windowrule = suppressevent maximize, class:.*

# Floating & centering for special windows
windowrulev2 = float, title:^(launcher)$
windowrulev2 = center, title:^(launcher)$
windowrulev2 = size 800 600, title:^(launcher)$
windowrulev2 = opacity $iopacity $oopacity, title:^(launcher)$

windowrulev2 = float, title:^(encfs-manager)$
windowrulev2 = center, title:^(encfs-manager)$
windowrulev2 = size 800 600, title:^(encfs-manager)$
windowrulev2 = opacity $iopacity $oopacity, title:^(encfs-manager)$

windowrulev2 = float, class:^(wallset)$
windowrulev2 = center, class:^(wallset)$
windowrulev2 = size 1336 564, class:^(wallset)$
windowrulev2 = opacity $iopacity $oopacity, class:^(wallset)$

# Dropdown terminal
exec-once = kitty --class=kitty-dropdown
windowrulev2 = float,class:^(kitty-dropdown)$
windowrulev2 = size 35% 40%,class:^(kitty-dropdown)$
windowrulev2 = move 30 50,class:^(kitty-dropdown)$
bind = $mainMod SHIFT, C, exec,~/.config/hypr/scripts/dropdown.sh

